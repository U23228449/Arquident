<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
    
    <!-- Información de la aplicación -->
    <display-name>ArquiDent - Clínica Dental</display-name>
    <description>
        Sistema de gestión para clínica dental ArquiDent.
        Permite la gestión de citas, pacientes, odontólogos y servicios.
    </description>
    
    <!-- Página de bienvenida -->
    <welcome-file-list>
        <welcome-file>inicio</welcome-file>
    </welcome-file-list>
    
    <!-- Configuración de sesión -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
    
    <!-- Configuración de encoding para caracteres especiales -->
    <filter>
        <filter-name>CharacterEncodingFilter</filter-name>
        <filter-class>org.apache.catalina.filters.SetCharacterEncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
        <init-param>
            <param-name>ignore</param-name>
            <param-value>false</param-value>
        </init-param>
    </filter>
    
    <filter-mapping>
        <filter-name>CharacterEncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
    
    <!-- CORREGIDO: Filtro de autenticación con patrones válidos -->
    <filter>
        <filter-name>AuthenticationFilter</filter-name>
        <filter-class>pe.edu.utp.filter.AuthenticationFilter</filter-class>
    </filter>
    
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/dashboard-paciente</url-pattern>
    </filter-mapping>
    
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/dashboard-odontologo</url-pattern>
    </filter-mapping>
    
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/dashboard-secretaria</url-pattern>
    </filter-mapping>
    
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/dashboard-admin</url-pattern>
    </filter-mapping>
    
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/reservar-cita</url-pattern>
    </filter-mapping>
    
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/mis-citas</url-pattern>
    </filter-mapping>
    
    <!-- Configuración de errores -->
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/views/error/404.jsp</location>
    </error-page>
    
    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/views/error/500.jsp</location>
    </error-page>
    
    <!-- Configuración de recursos estáticos -->
    <servlet-mapping>
        <servlet-name>default</servlet-name>
        <url-pattern>*.css</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>default</servlet-name>
        <url-pattern>*.js</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>default</servlet-name>
        <url-pattern>*.png</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>default</servlet-name>
        <url-pattern>*.jpg</url-pattern>
    </servlet-mapping>
    
    <!-- Configuración de MIME types -->
    <mime-mapping>
        <extension>css</extension>
        <mime-type>text/css</mime-type>
    </mime-mapping>
    
    <mime-mapping>
        <extension>js</extension>
        <mime-type>application/javascript</mime-type>
    </mime-mapping>
    
    <!-- Parámetros de contexto -->
    <context-param>
        <param-name>app.name</param-name>
        <param-value>ArquiDent</param-value>
    </context-param>
    
    <!-- Listener para limpiar el driver JDBC al cerrar la aplicación -->
    <listener>
        <listener-class>pe.edu.utp.listener.DatabaseCleanupListener</listener-class>
    </listener>
    
</web-app>
